{
  "name": "hetero-agents",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "A batteries-included template for heterogeneous agent routing in Claude Code — keep the orchestrator on Claude, route chosen subagents to OpenRouter models via a small owned proxy.",
  "author": "Armen Rostamian",
  "license": "MIT",
  "homepage": "https://github.com/armenr/hetero-agents#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/armenr/hetero-agents.git"
  },
  "bugs": {
    "url": "https://github.com/armenr/hetero-agents/issues"
  },
  "keywords": [
    "claude-code",
    "anthropic",
    "openrouter",
    "llm",
    "proxy",
    "subagents",
    "routing",
    "bun",
    "template"
  ],
  "scripts": {
    "proxy": "bun run src/server.ts",
    "hetero": "bun run bin/hetero",
    "test": "bun test test/",
    "test:live": "bun run scripts/live-smoke.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun test test/"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@types/bun": "^1.3.14",
    "eslint": "^9.10.0",
    "typescript": "^6.0.3"
  }
}
